# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# Strong random API key (generate with: openssl rand -hex 32)
API_KEY=change_me_to_a_strong_random_key_at_least_32_chars

# Port the server listens on (open this in UFW)
PORT=3241

# Absolute path to the directory where vault files will be stored on VPS
VAULT_PATH=/opt/vault

# Absolute path where backup versions are stored (outside vault, so they don't sync)
# Last 30 versions per file are kept automatically
BACKUP_PATH=/opt/vault-backups

NODE_ENV=production
